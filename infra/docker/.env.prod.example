# Copy to .env.prod and fill REAL values. Never commit .env.prod.
# Generate secrets:  openssl rand -base64 48

# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=traineon
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=traineon

# ── ClickHouse ────────────────────────────────────────────────────────────────
CLICKHOUSE_DB=traineon
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=change-me

# ── App secrets (min 32 chars each) ───────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-characters-long-xxxxx
JWT_REFRESH_SECRET=change-me-min-32-characters-long-yyyyy
# Master key that encrypts BYOK provider keys at rest — losing/rotating it
# invalidates every stored provider credential. Keep it safe.
CREDENTIAL_ENCRYPTION_KEY=change-me-min-32-characters-long-zzzzz

# ── Web / CORS ────────────────────────────────────────────────────────────────
# Origin(s) the browser app is served from (the web container / your domain).
CORS_ORIGINS=https://your-domain.example
WEB_PORT=80
LOG_LEVEL=info
