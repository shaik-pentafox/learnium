generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles ─────────────────────────────────────────────────────────────────────

model RoleDef {
  id    Int    @id @default(autoincrement())
  name  String @unique // SUPER_ADMIN | TRAINER | USER
  users User[]

  @@map("role_defs")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  employeeId   String    @unique
  email        String    @unique
  firstName    String
  lastName     String
  roleId       Int
  role         RoleDef   @relation(fields: [roleId], references: [id])
  supervisorId     Int?
  supervisor       User?    @relation("UserSupervisor", fields: [supervisorId], references: [id])
  supervisees      User[]   @relation("UserSupervisor")
  assignedPersonaId Int?
  assignedPersona  Persona? @relation("AssignedPersona", fields: [assignedPersonaId], references: [id])
  avatarUrl        String?
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  Int?
  updatedById  Int?

  credential      DefaultCredential?
  refreshTokens   RefreshToken[]
  realtimeTickets RealtimeTicket[]
  sessions        Session[]

  @@map("users")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model DefaultCredential {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  userId       Int    @unique
  user         User   @relation(fields: [userId], references: [id])

  @@map("default_credentials")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  familyId  String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model RealtimeTicket {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("realtime_tickets")
}

// ── Personas ──────────────────────────────────────────────────────────────────

model VoiceStyle {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  provider String    // elevenlabs | azure | google
  voiceId  String
  personas Persona[]

  @@map("voice_styles")
}

model Persona {
  id                 Int              @id @default(autoincrement())
  name               String
  description        String?
  systemPrompt       String
  customInstructions String?
  voiceStyleId       Int?
  voiceStyle         VoiceStyle?      @relation(fields: [voiceStyleId], references: [id])
  isDeleted          Boolean          @default(false)
  createdById        Int?
  updatedById        Int?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  versions           PersonaVersion[]
  scoreCriteria      ScoreCriterion[]
  assignedUsers      User[]           @relation("AssignedPersona")
  sessions           Session[]

  @@map("personas")
}

model PersonaVersion {
  id                 Int      @id @default(autoincrement())
  personaId          Int
  persona            Persona  @relation(fields: [personaId], references: [id])
  version            Int
  systemPrompt       String
  customInstructions String?
  snapshotData       Json
  createdById        Int?
  createdAt          DateTime @default(now())

  @@unique([personaId, version])
  @@index([personaId])
  @@map("persona_versions")
}

model ScoreCriterion {
  id          Int     @id @default(autoincrement())
  personaId   Int
  persona     Persona @relation(fields: [personaId], references: [id])
  name        String
  description String?
  maxScore    Int     @default(10)
  weight      Float   @default(1.0)
  order       Int     @default(0)

  scoreResults ScoreResult[]

  @@index([personaId])
  @@map("score_criteria")
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id        Int           @id @default(autoincrement())
  uid       String        @unique @default(uuid())
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  personaId Int
  persona   Persona       @relation(fields: [personaId], references: [id])
  status    String        @default("ACTIVE") // ACTIVE | COMPLETED | ABANDONED
  feedback  String?
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  scores    ScoreResult[]

  @@index([userId])
  @@index([personaId])
  @@map("sessions")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  session    Session  @relation(fields: [sessionId], references: [id])
  role       String   // user | assistant
  content    String
  tokenCount Int?
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

model ScoreResult {
  id          Int            @id @default(autoincrement())
  sessionId   Int
  session     Session        @relation(fields: [sessionId], references: [id])
  criterionId Int
  criterion   ScoreCriterion @relation(fields: [criterionId], references: [id])
  score       Float?
  maxScore    Int
  feedback    String?
  createdAt   DateTime       @default(now())

  @@index([sessionId])
  @@map("score_results")
}

// ── Bulk Import ───────────────────────────────────────────────────────────────

model ImportReport {
  id          String   @id @default(uuid())
  userId      Int
  status      String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errorData   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("import_reports")
}
