# Web app environment (Vite). Copy to .env.local for local overrides.
# Only VITE_-prefixed vars are exposed to the client.

# Dev data source. Default (mocks on): MSW intercepts /api/v1 with in-browser
# fixtures, so the app runs with no backend. Set to "false" to hit the live
# NestJS backend through the vite proxy (see server.proxy in vite.config.ts).
VITE_ENABLE_MOCKS=true
