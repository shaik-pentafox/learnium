generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Roles ─────────────────────────────────────────────────────────────────────

model RoleDef {
  id    Int    @id @default(autoincrement())
  name  String @unique // SUPER_ADMIN | TRAINER | USER
  users User[]

  @@map("role_defs")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  employeeId   String    @unique
  email        String    @unique
  firstName    String
  lastName     String
  roleId       Int
  role         RoleDef   @relation(fields: [roleId], references: [id])
  supervisorId     Int?
  supervisor       User?    @relation("UserSupervisor", fields: [supervisorId], references: [id])
  supervisees      User[]   @relation("UserSupervisor")
  assignedPersonaId Int?
  assignedPersona  Persona? @relation("AssignedPersona", fields: [assignedPersonaId], references: [id])
  avatarUrl        String?
  isDeleted    Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdById  Int?
  updatedById  Int?

  credential      DefaultCredential?
  refreshTokens   RefreshToken[]
  realtimeTickets RealtimeTicket[]
  sessions        Session[]

  @@map("users")
}

// ── Auth ──────────────────────────────────────────────────────────────────────

model DefaultCredential {
  id           Int    @id @default(autoincrement())
  username     String @unique
  passwordHash String
  userId       Int    @unique
  user         User   @relation(fields: [userId], references: [id])

  @@map("default_credentials")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  tokenHash String   @unique
  familyId  String
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

model RealtimeTicket {
  id        String   @id @default(uuid())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("realtime_tickets")
}

// ── Personas ──────────────────────────────────────────────────────────────────

model VoiceStyle {
  id       Int       @id @default(autoincrement())
  name     String    @unique
  provider String    // elevenlabs | azure | google
  voiceId  String
  personas Persona[]

  @@map("voice_styles")
}

// ── LLM Registry ─────────────────────────────────────────────────────────────

model LlmProvider {
  id               Int        @id @default(autoincrement())
  name             String     @unique
  type             String
  baseUrl          String?
  credentialRef    String?
  isEnabled        Boolean    @default(true)
  priority         Int        @default(0)
  monthlyBudgetUsd Float?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  models           LlmModel[]

  @@map("llm_providers")
}

model LlmModel {
  id                    Int          @id @default(autoincrement())
  name                  String       @unique
  providerId            Int
  provider              LlmProvider  @relation(fields: [providerId], references: [id])
  capabilities          String[]
  contextWindowTokens   Int?
  inputPricePerMillion  Float?
  outputPricePerMillion Float?
  isDefault             Boolean      @default(false)
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  conversationPersonas  Persona[]    @relation("ConversationModel")
  scoringPersonas       Persona[]    @relation("ScoringModel")

  @@map("llm_models")
}

// Per-call LLM usage + cost telemetry. Written on each chat turn / scoring run.
model LlmUsage {
  id           Int      @id @default(autoincrement())
  kind         String   // chat | scoring
  modelId      Int?
  modelName    String
  providerType String?
  sessionId    Int?
  userId       Int?
  inputTokens  Int      @default(0)
  outputTokens Int      @default(0)
  totalTokens  Int      @default(0)
  costUsd      Float    @default(0)
  estimated    Boolean  @default(false) // tokens approximated (provider returned no usage)
  latencyMs    Int?
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([modelId])
  @@map("llm_usage")
}

model Persona {
  id                  Int              @id @default(autoincrement())
  name                String
  description         String?
  // Hex accent color for the persona's chat orb/avatar (e.g. "#6366f1").
  color               String?
  isPublished         Boolean   @default(false)
  // Structured authoring fields (source of truth). The runtime prompt is
  // rendered from these; `systemPrompt` is a rendered cache kept for preview.
  templateData        Json?
  systemPrompt        String
  customInstructions  String?
  voiceStyleId        Int?
  voiceStyle          VoiceStyle?      @relation(fields: [voiceStyleId], references: [id])
  conversationModelId Int?
  conversationModel   LlmModel?        @relation("ConversationModel", fields: [conversationModelId], references: [id])
  scoringModelId      Int?
  scoringModel        LlmModel?        @relation("ScoringModel", fields: [scoringModelId], references: [id])
  isDeleted           Boolean          @default(false)
  createdById         Int?
  updatedById         Int?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  versions            PersonaVersion[]
  scoreCriteria       ScoreCriterion[]
  assignedUsers       User[]           @relation("AssignedPersona")
  sessions            Session[]

  @@map("personas")
}

model PersonaVersion {
  id                 Int      @id @default(autoincrement())
  personaId          Int
  persona            Persona  @relation(fields: [personaId], references: [id])
  version            Int
  templateData       Json?
  systemPrompt       String
  customInstructions String?
  snapshotData       Json
  createdById        Int?
  createdAt          DateTime @default(now())

  @@unique([personaId, version])
  @@index([personaId])
  @@map("persona_versions")
}

model ScoreCriterion {
  id          Int     @id @default(autoincrement())
  personaId   Int
  persona     Persona @relation(fields: [personaId], references: [id])
  name        String
  description String?
  maxScore    Int     @default(10)
  weight      Float   @default(1.0)
  order       Int     @default(0)

  scoreResults ScoreResult[]

  @@index([personaId])
  @@map("score_criteria")
}

// ── Sessions ──────────────────────────────────────────────────────────────────

model Session {
  id        Int           @id @default(autoincrement())
  uid       String        @unique @default(uuid())
  userId    Int
  user      User          @relation(fields: [userId], references: [id])
  personaId Int
  persona   Persona       @relation(fields: [personaId], references: [id])
  status    String        @default("ACTIVE") // ACTIVE | COMPLETED | ABANDONED
  feedback  String?
  isSimulation Boolean       @default(false)
  startedAt DateTime      @default(now())
  endedAt   DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  messages  ChatMessage[]
  scores    ScoreResult[]

  @@index([userId])
  @@index([personaId])
  @@map("sessions")
}

model ChatMessage {
  id         Int      @id @default(autoincrement())
  sessionId  Int
  session    Session  @relation(fields: [sessionId], references: [id])
  role       String   // user | assistant
  content    String
  tokenCount Int?
  /** Per-message timing (ms). assistant = LLM generation time; user = trainee
   *  response/think time since the previous message. */
  latencyMs  Int?
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@map("chat_messages")
}

model ScoreResult {
  id          Int            @id @default(autoincrement())
  sessionId   Int
  session     Session        @relation(fields: [sessionId], references: [id])
  criterionId Int
  criterion   ScoreCriterion @relation(fields: [criterionId], references: [id])
  score       Float?
  maxScore    Int
  feedback    String?
  createdAt   DateTime       @default(now())

  @@index([sessionId])
  @@map("score_results")
}

// ── Bulk Import ───────────────────────────────────────────────────────────────

model ImportReport {
  id          String   @id @default(uuid())
  userId      Int
  status      String   @default("PENDING") // PENDING | PROCESSING | DONE | FAILED
  totalRows   Int      @default(0)
  successRows Int      @default(0)
  errorRows   Int      @default(0)
  errorData   Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@map("import_reports")
}
