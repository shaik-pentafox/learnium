# ── App ──────────────────────────────────────
NODE_ENV=development
APP_ROLE=api
PORT=3000
CORS_ORIGINS=http://localhost:5173

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://learnium:learnium@localhost:5432/learnium_app
DATABASE_POOL_SIZE=5

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-random-secret
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_SECRET=change-me-different-min-32-chars-secret
JWT_REFRESH_TTL_SECONDS=604800
WS_TICKET_TTL_SECONDS=30

# ── LLM ───────────────────────────────────────
# No gateway. Providers + models + keys are configured at runtime via /llm
# (LangChain.js builds chat models in-process from the encrypted DB registry).

# AES-256-GCM key for encrypting provider API keys at rest (min 32 chars)
CREDENTIAL_ENCRYPTION_KEY=change-me-min-32-chars-random-secret

# ── Object storage (MinIO local) ──────────────
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9002
S3_BUCKET=learnium-content
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=learnium
S3_SECRET_ACCESS_KEY=learnium_secret

# ── ClickHouse ────────────────────────────────
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=learnium
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=

# ── Rate limiting ──────────────────────────────
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=100
THROTTLE_LOGIN_LIMIT=5

# ── Uploads ───────────────────────────────────
UPLOAD_MAX_VIDEO_MB=500
UPLOAD_MAX_DOC_MB=50

# ── Worker ────────────────────────────────────
WORKER_CONCURRENCY=5

# ── Observability ─────────────────────────────
LOG_LEVEL=debug
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# SENTRY_DSN=

# ── Credential verifier ───────────────────────
CREDENTIAL_VERIFIER=local
# EXTERNAL_AUTH_URL=
